---
import '../styles/global.css';
import Logo from '../components/Logo.astro';
const { title = 'GetEVReal', description = 'Electric vehicle buying journey, guides, interviews, and affiliate recommendations.' } = Astro.props;
---
<!doctype html><html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>{title}</title><meta name="description" content={description} /><meta property="og:title" content={title} /><meta property="og:description" content={description} /><meta property="og:type" content="website" /><meta property="og:image" content="https://images.unsplash.com/photo-1593941707882-a5bba53b3f87?auto=format&fit=crop&w=1200&q=80" /><link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cpath d='M18 42L31 16L46 42M24 36H40M49 20H55L52 30' fill='none' stroke='%2301696f' stroke-width='5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E" /></head><body><a class="skip-link" href="#content">Skip to content</a><header class="site-header"><div class="container header-inner"><a href="/" class="logo" aria-label="GetEVReal home"><Logo /><span>GetEVReal</span></a><nav class="nav-links" aria-label="Primary"><a href="/">Home</a><a href="/blog/">Articles</a><a href="/about/">About & Contact</a></nav><button class="theme-toggle" type="button" aria-label="Toggle theme" data-theme-toggle><span aria-hidden="true">◐</span></button></div></header><main id="content"><slot /></main><footer class="site-footer"><div class="container footer-grid"><div><strong>GetEVReal</strong><p class="notice">First-EV buying diary, practical guides, interviews, and affiliate-supported recommendations.</p></div><p class="notice">Add a clear FTC affiliate disclosure near recommendation blocks, comparison tables, and CTA buttons.</p></div></footer><script>const root=document.documentElement;const toggle=document.querySelector('[data-theme-toggle]');let theme=window.matchMedia('(prefers-color-scheme: dark)').matches?'dark':'light';root.setAttribute('data-theme',theme);toggle?.addEventListener('click',()=>{theme=theme==='dark'?'light':'dark';root.setAttribute('data-theme',theme);});</script></body></html>
