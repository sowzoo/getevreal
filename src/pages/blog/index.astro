---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a,b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---
<BaseLayout title="GetEVReal Articles" description="Browse EV buying guides, ownership diary entries, and interviews on GetEVReal.">
<section><div class="container"><div class="section-head"><p class="eyebrow">Articles and diary entries</p><h1 style="font-size:var(--text-2xl);font-family:var(--font-display);">Practical EV content that is easy to publish.</h1><p>Every post is a Markdown file in the Astro content collection, which keeps publishing simple and SEO-friendly.</p></div><div class="blog-list">{posts.map((post) => (<article class="article-card"><div class="article-meta"><span>{post.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span><span>{post.data.readTime}</span></div><h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3><p class="muted">{post.data.excerpt}</p><div class="badge-row">{post.data.tags.map((tag) => <span class="pill">{tag}</span>)}</div></article>))}</div></div></section>
</BaseLayout>
