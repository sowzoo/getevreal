---
import BaseLayout from '../layouts/BaseLayout.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
// 1. Import the image file
import localImage from '../assets/heropreciousmadubuike.jpg';
// 2. Import the Image component from astro:assets
import { Image } from 'astro:assets';
---
<BaseLayout title="GetEVReal | Real-world EV buying journey" description="GetEVReal helps first-time EV buyers compare models, learn charging basics, and follow one honest journey into electric car ownership.">
<section class="hero"><div class="container hero-grid"><div><p class="eyebrow">Electric without the hype</p><h1>Real-world journey to my first EV.</h1><p class="lead">GetEVReal is honest research, smarter comparisons, owner interviews, and a practical diary from someone making the leap to electric for the first time.</p><div class="cta-row"><a class="btn btn-primary" href="/blog/">Read buyer guides</a><a class="btn btn-secondary" href="/about/">Meet Mike</a></div><div class="badge-row"><span class="pill">Affiliate-ready product picks</span><span class="pill">YouTube, Instagram, TikTok friendly</span><span class="pill">Simple Astro blog workflow</span></div></div><div class="hero-card"><!-- 3. Use <Image /> and pass the object directly to src -->
        <Image 
          src={localImage} 
          alt="EV with power plugged in" 
          width="1200" 
          height="1400" 
          loading="lazy" 
        /><div class="metric-strip"><div><span class="mini-label">Audience</span><strong>20-40</strong><span class="muted">New EV shoppers.</span></div><div><span class="mini-label">Content</span><strong>Guides</strong><span class="muted">Reviews, interviews, diary.</span></div><div><span class="mini-label">Goal</span><strong>Convert</strong><span class="muted">Affiliate clicks plus trust.</span></div></div></div></div></section>
<section><div class="container split-grid"><div class="section-head"><p class="eyebrow">What belongs here</p><h2>A content engine built for trust and commissions.</h2><p>Use the homepage to spotlight your latest buyer guide, your personal EV diary, featured interviews, and your strongest affiliate categories like chargers, accessories, insurance tools, or financing offers.</p></div><div class="quote-card"><p>“I want this site to feel like a smart friend helping me avoid an expensive mistake.”</p></div></div><div class="container cards-3" style="margin-top:2rem;"><article class="feature-card"><span class="mini-label">Buyer education</span><h3>In-depth guides.</h3><p class="muted">Publish “best EV for commuters,” charging explainers, cost breakdowns, and first-time buyer checklists that answer commercial-intent questions.</p></article><article class="feature-card"><span class="mini-label">Social proof</span><h3>Interviews and creator content.</h3><p class="muted">Embed videos and short-form clips from YouTube, Instagram, and TikTok so readers can move from article to channel naturally.</p></article><article class="feature-card"><span class="mini-label">Monetization</span><h3>Affiliate placements that fit.</h3><p class="muted">Add comparison tables, “best for” cards, and CTA buttons after trust-building sections; keep disclosures visible near every monetized block.</p></article></div></section>
<section><div class="container about-grid"><div class="pull-visual"><img src={ localImage } alt="EV with power plugged in" width="1200" height="1400" loading="lazy" /></div><div class="section-head"><p class="eyebrow">Editorial direction</p><h2>Designed for the first-time EV shopper.</h2><p>The layout uses bold editorial type, energetic contrast, and practical sections so the site feels exciting without reading like dealership marketing. That makes it a better fit for younger professionals who have the budget to buy but still want plain-English answers.</p><div class="cards-3" style="grid-template-columns:1fr;gap:1rem;"><div class="card"><h3>Homepage hero.</h3><p class="muted">Feature one primary CTA, one latest article, and one social/video highlight.</p></div><div class="card"><h3>Blog system.</h3><p class="muted">New posts live in <code>src/content/blog</code> as Markdown files, so publishing stays simple.</p></div><div class="card"><h3>About/contact.</h3><p class="muted">Tell your story, link socials, and route the form to your email service.</p></div></div></div></div></section>
</BaseLayout>      